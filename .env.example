# Canonical site URL (used for metadata, sitemap, robots). Defaults to a
# placeholder when unset.
NEXT_PUBLIC_SITE_URL=https://marcoslott.dev

# Supabase — required for visitor tags and future data layer
#
# Local (after `yarn db:start` + `yarn db:status`):
#   NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#
# Production: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the client (NEXT_PUBLIC_*).
# Required for /api/visitor-tags. Without it the widget degrades gracefully.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
