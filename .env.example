# Canonical HTTPS origin (metadata, sitemap, robots, and redirect target).
# Production today: https://www.lott.dev.br
# When lott.dev also points to Vercel, switch to https://lott.dev and add
# alternate hosts to REDIRECT_HOSTS below.
NEXT_PUBLIC_SITE_URL=https://www.lott.dev.br

# Comma-separated hosts that should 308 to NEXT_PUBLIC_SITE_URL.
# Defaults: lott.dev.br, marcoslott.dev, www.marcoslott.dev
# REDIRECT_HOSTS=lott.dev.br,www.lott.dev.br

# Supabase — required for visitor tags and future data layer
#
# Local (after `yarn db:start` + `yarn db:status`):
#   NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#
# Production: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the client (NEXT_PUBLIC_*).
# Required for /api/visitor-tags. Without it the widget degrades gracefully.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
