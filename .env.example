# Canonical site URL (used for metadata, sitemap, robots). Defaults to a
# placeholder when unset.
NEXT_PUBLIC_SITE_URL=https://marcoslott.dev

# Supabase — required for data layer
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role — server-only, never expose to client.
# Required for the Visitor Tags widget to persist (see
# supabase/migrations/0001_visitor_tags.sql). Without it the widget degrades
# gracefully to an empty state.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
